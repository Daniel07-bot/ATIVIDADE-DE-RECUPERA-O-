programa{
	
inclua biblioteca Matematica --> mat
	
	funcao inicio(){

		real nota1, nota2, nota3, media_final

		escreva("Digite a primeira nota (peso 2): ")
		leia(nota1)
		escreva("Digite a segunda nota (peso 3): ")
		leia(nota2)
		escreva("Digite a terceira nota (peso 5): ")
		leia(nota3)
		media_final = ((nota1 * 2) + (nota2 * 3) + (nota3 * 5)) / 10.0

		media_final = mat.arredondar(media_final, 2)

		escreva("\nA média final do aluno é: ", media_final)
	}
}
