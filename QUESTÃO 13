programa{
	funcao inicio(){
		
    inteiro n1, n2, n3, maior

		escreva("Digite o primeiro valor inteiro: ")
		leia(n1)
		escreva("Digite o segundo valor inteiro: ")
		leia(n2)
		escreva("Digite o terceiro valor inteiro: ")
		leia(n3)

		escreva("\nValores digitados: ", n1, ", ", n2, ", ", n3, "\n")

		maior = n1

		se (n2 > maior)
		{
			maior = n2
		}
		se (n3 > maior)
		{
			maior = n3
		}
		escreva(maior, " É o maior")
	}
}
