programa{
	funcao inicio(){
		
    inteiro codigo

		escreva("Digite o código do produto: ")
		leia(codigo)

		escreva("\nCódigo inserido: ", codigo, "\n")

		se (codigo == 1)
		{
			escreva("\nClassificação: Alimento não-perecível\n")
		}
		senao se (codigo >= 2 e codigo <= 4)
		{
			escreva("\nClassificação: Alimento perecível\n")
		}
		senao se (codigo == 5 ou codigo == 6)
		{
			escreva("\nClassificação: Vestuário\n")
		}
		senao se (codigo == 7)
		{
			escreva("\nClassificação: Higiene pessoal\n")
		}
		senao se (codigo >= 8 e codigo <= 15)
		{
			escreva("\nClassificação: Limpeza e utensílios domésticos\n")
		}
		senao
		{
			escreva("\nClassificação: Código inválido\n")
		}
	}
}
