programa {
	inclua biblioteca Matematica --> mat
	funcao inicio(){
		inteiro A, B, C
		real R, S, D

		escreva("Digite o valor de A (inteiro e positivo): ")
		leia(A)
		escreva("Digite o valor de B (inteiro e positivo): ")
		leia(B)
		escreva("Digite o valor de C (inteiro e positivo): ")
		leia(C)

		R = mat.potencia(A + B, 2.0)
		S = mat.potencia(B + C, 2.0)
		
		D = (R + S) / 2.0

		escreva("\n--- RESULTADOS ---\n")
		escreva("\nValor de R: ", R)
		escreva("\nValor de S: ", S)
		escreva("\nO resultado da expressão D é: ", D)
	}
}
