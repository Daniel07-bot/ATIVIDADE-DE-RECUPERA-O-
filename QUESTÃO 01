programa {
	inclua biblioteca Matematica --> mat
	funcao inicio(){
	
		real x1, y1, x2, y2, distancia

		escreva("Digite a coordenada x do primeiro ponto (x1): ")
		leia(x1)
		escreva("Digite a coordenada y do primeiro ponto (y1): ")
		leia(y1)
		escreva("Digite a coordenada x do segundo ponto (x2): ")
		leia(x2)
		escreva("Digite a coordenada y do segundo ponto (y2): ")
		leia(y2)

		distancia = mat.raiz(mat.potencia(x2 - x1, 2.0) + mat.potencia(y2 - y1, 2.0), 2.0)

		distancia = mat.arredondar(distancia, 2)

		escreva("A distância entre os dois pontos é: ", distancia)
	}
}
